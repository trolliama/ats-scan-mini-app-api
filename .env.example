# Logging
LOG_LEVEL=INFO
LOG_ENV=dev
LOG_COLOR=true

# ATS scan worker — required for POST /scans and background pipeline
API_KEY=change-me-shared-secret-with-nextjs

# SQLite persistence (parent directory is created automatically)
SQLITE_PATH=data/scans.db

# Outbound webhooks to Next.js
NEXT_WEBHOOK_URL=http://localhost:3000/api/ats/webhook
WEBHOOK_SECRET=change-me-webhook-hmac-secret

# S3 / MinIO — FastAPI fetches resume PDFs with these credentials
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=resumes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# LLM provider (optional in P1; required in P2 when agent_mode=llm)
# OPENAI_API_KEY=sk-...
